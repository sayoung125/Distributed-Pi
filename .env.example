# Distributed Pi Video Analytics - Environment Configuration
# Copy this file to .env and update with your network settings
#
# Hardware mapping:
#   Pi Zero       -> MQTT Broker
#   Pi 3          -> Intelligence Layer (Ollama/TinyLlama)
#   Pi 4 2GB      -> Vision Detector (YOLOv8-nano)
#   Pi 4 4GB      -> Frame Processor + Web Dashboard

# MQTT Broker (Pi Zero IP address)
MQTT_BROKER_HOST=10.0.0.10
MQTT_PORT=1883

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Pi 4 4GB specific (processor + dashboard)
CAMERA_INDEX=0

# Pi 4 2GB specific (vision)
CONFIDENCE_THRESHOLD=0.4

# Pi 3 specific (intelligence)
OLLAMA_MODEL=tinyllama
