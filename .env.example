# Distributed Pi Video Analytics - Environment Configuration
# Copy this file to .env and update with your network settings

# MQTT Broker (Pi Zero IP address)
MQTT_BROKER_HOST=10.0.0.10
MQTT_PORT=1883

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Pi 1 specific
CAMERA_INDEX=0

# Pi 2 specific
CONFIDENCE_THRESHOLD=0.4

# Pi 3 specific
OLLAMA_MODEL=tinyllama
